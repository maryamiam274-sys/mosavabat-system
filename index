<script>
    // تنظیمات JSONBin
    const BIN_ID = '6a21878ef5f4af5e29b86632';
    const MASTER_KEY = '$2a$10$6a21878ef5f4af5e29b86632'; // نکته: کلید معمولا با $2a$ شروع می‌شود، اگر دقیقا همان مقدار ارسالی شماست، آن را اصلاح کنید.
    const API_URL = `https://api.jsonbin.io/v3/b/${BIN_ID}`;

    const USERS = [
        { id: 'admin', name: 'مدیر سیستم', role: 'admin', pass: '123' },
        { id: 'user1', name: 'کاربر ۱', role: 'user', pass: '1' },
        { id: 'user2', name: 'کاربر ۲', role: 'user', pass: '2' }
    ];

    let currentUser = null;
    let meetings = [];
    let resolutions = [];

    // --- توابع ارتباط با سرور ---
    async function saveDataToCloud() {
        showLoading(true);
        try {
            const response = await fetch(API_URL, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Master-Key': MASTER_KEY
                },
                body: JSON.stringify({ meetings, resolutions })
            });
            if (!response.ok) throw new Error('خطا در ذخیره سازی ابری');
        } catch (error) {
            alert('خطا در اتصال به سرور: ' + error.message);
        } finally {
            showLoading(false);
        }
    }

    async function loadDataFromCloud() {
        showLoading(true);
        try {
            const response = await fetch(`${API_URL}/latest`, {
                headers: { 'X-Master-Key': MASTER_KEY }
            });
            if (!response.ok) throw new Error('خطا در دریافت داده‌ها');
            const data = await response.json();
            meetings = data.record.meetings || [];
            resolutions = data.record.resolutions || [];
            refreshUI();
        } catch (error) {
            console.error('Data load error:', error);
        } finally {
            showLoading(false);
        }
    }

    function showLoading(show) {
        // می‌توانید یک المان Loading به HTML اضافه کنید
        console.log(show ? "در حال هماهنگی با سرور..." : "به‌روزرسانی کامل شد.");
    }

    // --- توابع اصلی سامانه ---
    function doLogin() {
        const u = document.getElementById('username').value;
        const p = document.getElementById('password').value;
        const user = USERS.find(x => x.id === u && x.pass === p);

        if (user) {
            currentUser = user;
            document.getElementById('login-page').classList.remove('active');
            document.getElementById('main-app').classList.add('active');
            document.getElementById('display-user-name').innerText = user.name;
            
            if (user.role === 'admin') {
                document.body.classList.add('is-admin');
            } else {
                document.body.classList.remove('is-admin');
            }
            
            initApp();
        } else {
            alert('نام کاربری یا رمز عبور اشتباه است');
        }
    }

    async function initApp() {
        fillUserSelects();
        fillMeetingSelect();
        generateCode();
        await loadDataFromCloud(); // خواندن داده‌ها از ابر در هنگام شروع
    }

    function refreshUI() {
        renderDashboard();
        renderMeetings();
        renderResolutions();
        fillMeetingSelect();
    }

    // ذخیره مصوبه جدید
    async function saveResolution() {
        if (currentUser.role !== 'admin') return;
        
        const res = {
            id: Date.now(),
            code: document.getElementById('res-code').value,
            title: document.getElementById('res-title').value,
            meetingId: document.getElementById('res-meeting').value,
            owner: document.getElementById('res-owner').value,
            deadline: document.getElementById('res-deadline').value,
            status: 'pending'
        };

        if(!res.title || !res.owner || !res.deadline) {
            alert('لطفا فیلدهای ضروری را پر کنید');
            return;
        }

        resolutions.push(res);
        await saveDataToCloud(); // ذخیره در ابر
        
        document.getElementById('res-title').value = '';
        generateCode();
        showSection('resolutions');
        refreshUI();
    }

    // تغییر وضعیت مصوبه
    async function changeStatus(id) {
        const idx = resolutions.findIndex(r => r.id === id);
        if (idx === -1) return;

        const s = resolutions[idx].status;
        if (s === 'pending') resolutions[idx].status = 'progress';
        else if (s === 'progress') resolutions[idx].status = 'done';
        else resolutions[idx].status = 'pending';

        await saveDataToCloud();
        refreshUI();
    }

    // حذف مصوبه
    async function deleteResolution(id) {
        if (currentUser.role !== 'admin') return;
        if (!confirm('آیا از حذف این مصوبه مطمئن هستید؟')) return;

        resolutions = resolutions.filter(r => r.id !== id);
        await saveDataToCloud();
        refreshUI();
    }

    // ذخیره صورتجلسه جدید
    async function saveMeeting() {
        if (currentUser.role !== 'admin') return;

        const m = {
            id: 'm-' + Date.now(),
            title: document.getElementById('m-title').value,
            date: document.getElementById('m-date').value,
            location: document.getElementById('m-location').value
        };

        if(!m.title || !m.date) {
            alert('عنوان و تاریخ الزامی است');
            return;
        }

        meetings.push(m);
        await saveDataToCloud();
        
        document.getElementById('m-title').value = '';
        showSection('meetings');
        refreshUI();
    }

    // سایر توابع نمایش (render) مشابه کد قبلی شماست و فقط refreshUI را صدا می‌زنند
    // ... (توابع renderDashboard, renderMeetings, renderResolutions را از فایل خودتان اینجا قرار دهید)
</script>
